{
  "name": "delivery-command-center",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "api",
    "client"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "postinstall": "npm run db:generate",
    "dev": "npm run dev --workspace api",
    "dev:client": "npm run dev --workspace client",
    "dev:api": "npm run dev --workspace api",
    "start": "npm run db:migrate && npm run start --workspace api",
    "db:generate": "npm run db:generate --workspace api",
    "db:push": "npm run db:push --workspace api",
    "db:migrate": "npm run db:migrate --workspace api",
    "db:seed": "npm run db:seed --workspace api",
    "db:seed-master": "npm run db:seed-master --workspace api",
    "db:upsert-sap-modules": "npm run db:upsert-sap-modules --workspace api",
    "db:upsert-overhead-rules": "npm run db:upsert-overhead-rules --workspace api",
    "db:import-json": "npm run db:import-json --workspace api",
    "db:import-full-json:dev": "npm run db:import-full-json:dev --workspace api",
    "smoke:data-entry": "node api/scripts/dataEntrySmoke.js",
    "build": "npm run db:generate && npm run build --workspace client",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
